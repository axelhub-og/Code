-- 1. CODE TAB (ระบบ Redeem)
---
local CodeTab = Window:CreateTab({
    Name = "Code",
    Icon = "qr_code",
    ImageSource = "Material",
    ShowTitle = true
})

CodeTab:CreateButton({
    Name = "Redeem All Code",
    Description = "กดเพื่อใส่โค้ดทั้งหมดอัตโนมัติ",
    Callback = function()
        task.spawn(function()
            local player = game:GetService("Players").LocalPlayer
            local playerGui = player:WaitForChild("PlayerGui")
            
            local openBtn = playerGui:FindFirstChild("BasicStatsCurrencyAndButtonsUI")
                and playerGui.BasicStatsCurrencyAndButtonsUI.MainFrame.UIButtons:FindFirstChild("SettingsButtonFrame")
            
            if openBtn then
                local ox = openBtn.AbsolutePosition.X + (openBtn.AbsoluteSize.X / 2)
                local oy = openBtn.AbsolutePosition.Y + (openBtn.AbsoluteSize.Y / 2) + 58
                VIM:SendMouseButtonEvent(ox, oy, 0, true, game, 1)
                task.wait(0.1)
                VIM:SendMouseButtonEvent(ox, oy, 0, false, game, 1)
                task.wait(1) 
            end

            local scrollingFrame = playerGui:FindFirstChild("SettingsUI")
                and playerGui.SettingsUI.MainFrame.Frame.Content:FindFirstChild("SettingsTabFrame")
            
            if scrollingFrame and scrollingFrame:IsA("ScrollingFrame") then
                scrollingFrame.CanvasPosition = Vector2.new(0, 5000) 
                task.wait(1) 
            end

            local settingsUI = playerGui:FindFirstChild("SettingsUI")
            local base = settingsUI and settingsUI.MainFrame.Frame.Content.SettingsTabFrame.SettingCodes.Holder
            
            local codeBox = base and base.CodesBox:FindFirstChild("CodeBox")
            local redeemBtn = base and base.Holder:FindFirstChild("Redeem")

            if not redeemBtn or not codeBox then
                Luna:Notification({
                    Title = "Error",
                    Content = "ไม่พบตำแหน่งปุ่ม! กรุณาลองใหม่อีกครั้ง",
                    Icon = "error",
                    ImageSource = "Material"
                })
                return
            end

            for i, codeName in pairs(activeCodes) do
                codeBox.Text = ""
                task.wait(0.3)
                codeBox.Text = codeName
                task.wait(0.7) 
              
                local rx = redeemBtn.AbsolutePosition.X + (redeemBtn.AbsoluteSize.X / 2)
                local ry = redeemBtn.AbsolutePosition.Y + (redeemBtn.AbsoluteSize.Y / 2) + 58
                
                VIM:SendMouseButtonEvent(rx, ry, 0, true, game, 1)
                task.wait(0.2)
                VIM:SendMouseButtonEvent(rx, ry, 0, false, game, 1)

                pcall(function()
                    local args = { codeName }
                    game:GetService("ReplicatedStorage"):WaitForChild("RemoteEvents"):WaitForChild("CodeRedeem"):InvokeServer(unpack(args))
                end)

                Luna:Notification({
                    Title = "Redeeming", 
                    Content = "กำลังใส่โค้ด: " .. codeName .. " (" .. i .. "/" .. #activeCodes .. ")", 
                    Icon = "sync",
                    ImageSource = "Material"
                })
                
                task.wait(1.5) 
            end

            local closeBtn = playerGui:FindFirstChild("SettingsUI")
                and playerGui.SettingsUI.MainFrame.Frame:FindFirstChild("CloseButtonFrame")
            
            if closeBtn then
                task.wait(0.5)
                local cx = closeBtn.AbsolutePosition.X + (closeBtn.AbsoluteSize.X / 2)
                local cy = closeBtn.AbsolutePosition.Y + (closeBtn.AbsoluteSize.Y / 2) + 58
                
                VIM:SendMouseButtonEvent(cx, cy, 0, true, game, 1)
                task.wait(0.1)
                VIM:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
            end

            Luna:Notification({
                Title = "Success!",
                Content = "Redeem โค้ดทั้งหมดเรียบร้อยแล้ว",
                Icon = "check_circle",
                ImageSource = "Material"
            })
        end)
    end
})

